# Core
APP_ENV=dev
SECRET_KEY=change-me-32-bytes-of-randomness
PUBLIC_BASE_URL=https://beepbop.berlayar.ai
DATABASE_URL=sqlite:///./data/beepbop.db

# Google OAuth (create credentials at https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: https://beepbop.berlayar.ai/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (for matching, keyword decomposition, policy engine, email drafting)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram (create via @BotFather, then DM the bot once and grab chat_id from getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Genspark CLI — configured via `gsk login` (no env var needed if gsk session is active)
# Used for: slides, sheets, email send, phone call, calendar
GSK_PROJECT_ID=

# Demo behavior
DEMO_MODE=true
MOCK_REPLY_SECONDS=10
SCRAPE_TIMEOUT_SECONDS=180
